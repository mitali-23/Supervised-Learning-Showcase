   "source": [
    "# are now removing outliers from the dataset to improve model accuracy.\n",
    "b = Winsorizer(capping_method='iqr',\n",
    "               tail='both',\n",
    "               fold=1.5,\n",
    "               variables=['hsc_p'])\n",
    "df['hsc_p']=b.fit_transform(df[['hsc_p']])"
   ]
  },
  {
